# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# keep sample env file in git
!.env.example

# local IDE/MCP config (can contain tokens)
.cursor/

# GC saved session (contains auth cookies — never commit)
gc-session.json
gc-session-secret.txt

# GC team URLs (contains team IDs — keep local only)
gc-team-urls.txt
gc-game-debug*.png
gc-game-api-responses.json
gc-stats-debug.png
gc-stats-page-text.txt
gc-login-debug.png
